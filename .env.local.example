# =============================================================================
# BatchTrack Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key - ONLY for server-side operations (webhooks)
# Keep this secret! Never expose to client-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Site Configuration (Required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Paddle Billing (Required for subscriptions)
# Get these from: https://vendors.paddle.com/authentication
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxxxxxxxxxxxxxx

# Webhook secret for verifying Paddle webhooks
PADDLE_WEBHOOK_SECRET=pdl_whsec_xxxxxxxxxxxxxxxx

# Price IDs - Create products in Paddle Dashboard first
# Sandbox: https://sandbox-vendors.paddle.com/
# Production: https://vendors.paddle.com/
NEXT_PUBLIC_PADDLE_STARTER_MONTHLY=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_STARTER_YEARLY=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRO_MONTHLY=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_PRO_YEARLY=pri_xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Email - Resend (Required for transactional emails)
# Get your API key from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Analytics - Google Analytics (Optional)
# Get Measurement ID from: https://analytics.google.com/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Error Monitoring - Sentry (Optional but recommended for production)
# Get DSN from: https://mario-pi9.sentry.io/settings/projects/batchtrack/keys/
# Get Auth Token from: https://sentry.io/settings/auth-tokens/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o4510782522195968.ingest.us.sentry.io/xxxxxxxx
SENTRY_ORG=mario-pi9
SENTRY_PROJECT=batchtrack
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxx
